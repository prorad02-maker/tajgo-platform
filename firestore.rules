rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isCourier() {
      return signedIn()
        && exists(/databases/$(database)/documents/couriers/$(request.auth.uid))
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data
          .get('courierStatus', 'none') == 'approved'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data
          .get('courierOnboardingCompleted', false) == true
        && 'courier' in get(
          /databases/$(database)/documents/users/$(request.auth.uid)
        ).data.get('roles', []);
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
          == 'admin';
    }

    function authPhone() {
      return request.auth.token.get('phone_number', null);
    }

    function phoneMatchesAuth(data) {
      return data.get('phoneNumber', null) == null
        || data.get('phoneNumber', null) == authPhone();
    }

    match /users/{uid} {
      function accountFieldsAreWellFormed(data) {
        let roles = data.get('roles', ['customer']);
        let status = data.get('courierStatus', 'none');
        let mode = data.get('lastMode', 'customer');
        return roles is list
          && roles.hasOnly(['customer', 'courier'])
          && 'customer' in roles
          && status in [
            'none', 'draft', 'pending', 'approved', 'rejected', 'suspended'
          ]
          && mode in ['customer', 'courier']
          && data.get('phoneVerified', false) == (authPhone() != null)
          && data.get('profileComplete', false) is bool
          && data.get('courierOnboardingCompleted', false) is bool
          && (!data.get('courierOnboardingCompleted', false)
            || (status == 'approved' && 'courier' in roles));
      }

      function hasLegacyCourierProof(uid) {
        return resource.data.get('role', 'customer') == 'courier'
          || exists(/databases/$(database)/documents/couriers/$(uid));
      }

      function ownerRolesAreValid(uid) {
        let before = resource.data.get('roles', ['customer']);
        let after = request.resource.data.get('roles', ['customer']);
        return after == before
          || (hasLegacyCourierProof(uid)
            && after.hasOnly(['customer', 'courier'])
            && 'customer' in after
            && 'courier' in after);
      }

      function ownerCourierStatusIsValid(uid) {
        let before = resource.data.get('courierStatus', 'none');
        let after = request.resource.data.get('courierStatus', 'none');
        return after == before
          || (before == 'none' && after == 'draft')
          || (before == 'draft' && after == 'pending')
          || (before == 'rejected' && after in ['draft', 'pending'])
          || (hasLegacyCourierProof(uid) && after == 'approved');
      }

      function ownerModeAndLegacyRoleAreValid() {
        let mode = request.resource.data.get('lastMode', 'customer');
        let status = request.resource.data.get('courierStatus', 'none');
        let roles = request.resource.data.get('roles', ['customer']);
        let beforeRole = resource.data.get('role', 'customer');
        let afterRole = request.resource.data.get('role', 'customer');
        let courierModeAllowed = status == 'approved' && 'courier' in roles;
        return (mode == 'customer' || courierModeAllowed)
          && (beforeRole == 'admin'
            ? afterRole == 'admin'
            : (afterRole == 'customer'
              || (afterRole == 'courier' && courierModeAllowed)));
      }

      allow get: if owns(uid) || isAdmin();
      allow list: if isAdmin();

      allow create: if owns(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role == 'customer'
        && request.resource.data.get('roles', ['customer']).hasOnly([
          'customer'
        ])
        && request.resource.data.get('lastMode', 'customer') == 'customer'
        && request.resource.data.get('courierStatus', 'none') in [
          'none', 'draft'
        ]
        && accountFieldsAreWellFormed(request.resource.data)
        && phoneMatchesAuth(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if (owns(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt
        && phoneMatchesAuth(request.resource.data)
        && accountFieldsAreWellFormed(request.resource.data)
        && ownerRolesAreValid(uid)
        && ownerCourierStatusIsValid(uid)
        && ownerModeAndLegacyRoleAreValid()
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'phoneNumber',
          'displayName',
          'name',
          'photoUrl',
          'roles',
          'lastMode',
          'courierStatus',
          'phoneVerified',
          'profileComplete',
          'courierOnboardingCompleted',
          'targetRole',
          'role',
          'city',
          'language',
          'updatedAt'
        ])) || (isAdmin()
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time);

      allow delete: if false;
    }

    match /courier_applications/{uid} {
      function applicationDataIsValid(data) {
        return data.uid == uid
          && data.get('status', 'draft') in [
            'draft', 'pending', 'approved', 'rejected', 'suspended'
          ]
          && data.get('currentStep', 0) is int
          && data.get('currentStep', 0) >= 0
          && data.get('currentStep', 0) <= 4
          && data.get('transport', 'electric_bike') in [
            'walking', 'bicycle', 'electric_bike', 'scooter'
          ]
          && data.get('termsAccepted', false) is bool
          && data.get('dataConsent', false) is bool
          && phoneMatchesAuth(data);
      }

      function ownerDraftUpdateIsValid() {
        let before = resource.data.status;
        let after = request.resource.data.status;
        return owns(uid)
          && before in ['draft', 'rejected']
          && after in ['draft', 'pending']
          && applicationDataIsValid(request.resource.data)
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.updatedAt == request.time
          && (after != 'pending'
            || request.resource.data.submittedAt == request.time)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'displayName',
            'name',
            'phoneNumber',
            'status',
            'currentStep',
            'birthDate',
            'profilePhotoUrl',
            'transport',
            'documentType',
            'documentNumber',
            'documentPhotoUrl',
            'transportPhotoUrl',
            'city',
            'workDistrict',
            'availability',
            'termsAccepted',
            'dataConsent',
            'storageEnabled',
            'verificationMethod',
            'submittedAt',
            'updatedAt'
          ]);
      }

      allow get: if owns(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin() || (owns(uid)
        && request.resource.data.status == 'draft'
        && applicationDataIsValid(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time);
      allow update: if ownerDraftUpdateIsValid() || isAdmin();
      allow delete: if false;
    }

    match /couriers/{uid} {
      function baseCourierDataIsValid() {
        return request.resource.data.uid == uid
          && phoneMatchesAuth(request.resource.data)
          && request.resource.data.get('isOnline', false)
            == request.resource.data.get('online', false);
      }

      function ownerProfileUpdateIsValid() {
        return owns(uid)
          && isCourier()
          && baseCourierDataIsValid()
          && request.resource.data.updatedAt == request.time
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'phoneNumber',
            'displayName',
            'name',
            'city',
            'isOnline',
            'online',
            'transport',
            'location',
            'locationUpdatedAt',
            'heading',
            'speed',
            'locationAccuracy',
            'updatedAt'
          ]);
      }

      function ownerAcceptUpdateIsValid() {
        let orderId = request.resource.data.get('activeOrderId', null);
        let orderAfter = getAfter(
          /databases/$(database)/documents/orders/$(orderId)
        );
        return owns(uid)
          && resource.data.get('activeOrderId', null) == null
          && orderId is string
          && orderAfter.data.courierId == uid
          && orderAfter.data.status == 'accepted'
          && request.resource.data.updatedAt == request.time
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'activeOrderId',
            'updatedAt'
          ]);
      }

      function completionStatsUpdateIsValid() {
        let orderId = resource.data.get('activeOrderId', null);
        let orderAfter = getAfter(
          /databases/$(database)/documents/orders/$(orderId)
        );
        return orderId is string
          && orderAfter.data.courierId == uid
          && orderAfter.data.status == 'completed'
          && request.resource.data.get('activeOrderId', null) == null
          && request.resource.data.earningsToday
            == resource.data.earningsToday + orderAfter.data.price
          && request.resource.data.ordersToday == resource.data.ordersToday + 1
          && request.resource.data.updatedAt == request.time
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'activeOrderId',
            'earningsToday',
            'ordersToday',
            'updatedAt'
          ]);
      }

      function assignedCustomerCompletesOrder() {
        let orderId = resource.data.get('activeOrderId', null);
        let orderAfter = getAfter(
          /databases/$(database)/documents/orders/$(orderId)
        );
        return signedIn()
          && orderId is string
          && orderAfter.data.customerId == request.auth.uid
          && completionStatsUpdateIsValid();
      }

      allow get: if owns(uid) || isAdmin();
      allow list: if isAdmin();

      allow create: if isAdmin() || (owns(uid)
        && isCourier()
        && baseCourierDataIsValid()
        && request.resource.data.rating == 5
        && request.resource.data.score == 100
        && request.resource.data.earningsToday == 0
        && request.resource.data.ordersToday == 0
        && request.resource.data.get('activeOrderId', null) == null
        && request.resource.data.updatedAt == request.time);

      allow update: if ownerProfileUpdateIsValid()
        || ownerAcceptUpdateIsValid()
        || (owns(uid) && completionStatsUpdateIsValid())
        || assignedCustomerCompletesOrder()
        || isAdmin();

      allow delete: if false;
    }

    // Public projection used by the live map and customer tracking. Sensitive
    // courier fields (phone, activeOrderId and earnings) never live here.
    match /courier_public/{uid} {
      function assignedCustomerCanRead() {
        let privateCourier = get(
          /databases/$(database)/documents/couriers/$(uid)
        );
        let orderId = privateCourier.data.get('activeOrderId', null);
        return signedIn()
          && orderId is string
          && exists(/databases/$(database)/documents/orders/$(orderId))
          && get(/databases/$(database)/documents/orders/$(orderId)).data.customerId
            == request.auth.uid;
      }

      function publicDataMatchesPrivate() {
        let privateAfter = getAfter(
          /databases/$(database)/documents/couriers/$(uid)
        );
        return request.resource.data.uid == uid
          && request.resource.data.displayName == privateAfter.data.displayName
          && request.resource.data.name == privateAfter.data.name
          && request.resource.data.isOnline == privateAfter.data.isOnline
          && request.resource.data.online == privateAfter.data.online
          && request.resource.data.rating == privateAfter.data.rating
          && request.resource.data.transport == privateAfter.data.transport
          && request.resource.data.get('location', null)
            == privateAfter.data.get('location', null)
          && request.resource.data.get('locationUpdatedAt', null)
            == privateAfter.data.get('locationUpdatedAt', null)
          && request.resource.data.get('heading', null)
            == privateAfter.data.get('heading', null)
          && request.resource.data.get('speed', null)
            == privateAfter.data.get('speed', null)
          && request.resource.data.get('locationAccuracy', null)
            == privateAfter.data.get('locationAccuracy', null)
          && request.resource.data.updatedAt == request.time
          && request.resource.data.keys().hasOnly([
            'uid',
            'displayName',
            'name',
            'isOnline',
            'online',
            'rating',
            'transport',
            'location',
            'locationUpdatedAt',
            'heading',
            'speed',
            'locationAccuracy',
            'updatedAt'
          ]);
      }

      allow get: if signedIn()
        && (owns(uid)
          || isAdmin()
          || resource.data.get('isOnline', false) == true
          || assignedCustomerCanRead());
      allow list: if isAdmin()
        || (signedIn()
          && resource.data.get('isOnline', false) == true
          && request.query.limit != null
          && request.query.limit <= 50);

      allow create, update: if (owns(uid)
          && isCourier()
          && publicDataMatchesPrivate())
        || isAdmin();
      allow delete: if false;
    }

    match /orders/{orderId} {
      function immutableOrderData() {
        return request.resource.data.customerId == resource.data.customerId
          && request.resource.data.customerName == resource.data.customerName
          && request.resource.data.type == resource.data.type
          && request.resource.data.city == resource.data.city
          && request.resource.data.fromText == resource.data.fromText
          && request.resource.data.toText == resource.data.toText
          && request.resource.data.price == resource.data.price
          && request.resource.data.currency == resource.data.currency
          && request.resource.data.get('fromLocation', null)
            == resource.data.get('fromLocation', null)
          && request.resource.data.get('toLocation', null)
            == resource.data.get('toLocation', null)
          && request.resource.data.get('distanceKm', null)
            == resource.data.get('distanceKm', null)
          && request.resource.data.get('etaMinutes', null)
            == resource.data.get('etaMinutes', null)
          && request.resource.data.get('confirmationCode', null)
            == resource.data.get('confirmationCode', null)
          && request.resource.data.get('comment', null)
            == resource.data.get('comment', null)
          && request.resource.data.get('isTestOrder', false)
            == resource.data.get('isTestOrder', false)
          && request.resource.data.createdAt == resource.data.createdAt;
      }

      function customerCancels() {
        return resource.data.customerId == request.auth.uid
          && resource.data.status == 'waiting'
          && request.resource.data.status == 'cancelled'
          && request.resource.data.updatedAt == request.time
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'updatedAt'
          ]);
      }

      function customerCompletes() {
        let courierId = resource.data.get('courierId', null);
        let courierBefore = get(
          /databases/$(database)/documents/couriers/$(courierId)
        );
        let courierAfter = getAfter(
          /databases/$(database)/documents/couriers/$(courierId)
        );
        return courierId is string
          && resource.data.customerId == request.auth.uid
          && resource.data.status == 'delivered'
          && request.resource.data.status == 'completed'
          && request.resource.data.completedAt == request.time
          && request.resource.data.updatedAt == request.time
          && courierBefore.data.get('activeOrderId', null) == orderId
          && courierAfter.data.get('activeOrderId', null) == null
          && courierAfter.data.earningsToday
            == courierBefore.data.earningsToday + resource.data.price
          && courierAfter.data.ordersToday
            == courierBefore.data.ordersToday + 1
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'completedAt',
            'updatedAt'
          ]);
      }

      function customerDisputes() {
        return resource.data.customerId == request.auth.uid
          && resource.data.status == 'delivered'
          && request.resource.data.status == 'disputed'
          && request.resource.data.disputedAt == request.time
          && request.resource.data.updatedAt == request.time
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'disputedAt',
            'updatedAt'
          ]);
      }

      function courierDeclines() {
        return isCourier()
          && resource.data.status == 'waiting'
          && request.resource.data.status == 'waiting'
          && request.auth.uid in request.resource.data.declinedBy
          && request.resource.data.declinedBy.size()
            <= resource.data.declinedBy.size() + 1
          && request.resource.data.updatedAt == request.time
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'declinedBy',
            'updatedAt'
          ]);
      }

      function courierAccepts() {
        let courierAfter = getAfter(
          /databases/$(database)/documents/couriers/$(request.auth.uid)
        );
        return isCourier()
          && resource.data.status == 'waiting'
          && request.resource.data.status == 'accepted'
          && request.resource.data.courierId == request.auth.uid
          && courierAfter.data.get('activeOrderId', null) == orderId
          && request.resource.data.acceptedAt == request.time
          && request.resource.data.updatedAt == request.time
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'courierId',
            'acceptedAt',
            'updatedAt'
          ]);
      }

      function assignedCourierUpdates() {
        return isCourier()
          && resource.data.courierId == request.auth.uid
          && request.resource.data.courierId == request.auth.uid;
      }

      function courierArrives() {
        return assignedCourierUpdates()
          && resource.data.status == 'accepted'
          && request.resource.data.status == 'accepted'
          && request.resource.data.arrivedAtPickupAt == request.time
          && request.resource.data.updatedAt == request.time
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'arrivedAtPickupAt',
            'updatedAt'
          ]);
      }

      function courierPicksUp() {
        return assignedCourierUpdates()
          && resource.data.status == 'accepted'
          && resource.data.get('arrivedAtPickupAt', null) != null
          && request.resource.data.status == 'pickedUp'
          && request.resource.data.updatedAt == request.time
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'updatedAt'
          ]);
      }

      function courierDelivers() {
        return assignedCourierUpdates()
          && resource.data.status == 'pickedUp'
          && request.resource.data.status == 'delivered'
          && request.resource.data.updatedAt == request.time
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'updatedAt'
          ]);
      }

      function courierCompletesWithCode() {
        let courierAfter = getAfter(
          /databases/$(database)/documents/couriers/$(request.auth.uid)
        );
        return assignedCourierUpdates()
          && resource.data.status == 'pickedUp'
          && request.resource.data.status == 'completed'
          && request.resource.data.completedAt == request.time
          && request.resource.data.updatedAt == request.time
          && courierAfter.data.get('activeOrderId', null) == null
          && courierAfter.data.earningsToday
            == get(/databases/$(database)/documents/couriers/$(request.auth.uid)).data.earningsToday
              + resource.data.price
          && courierAfter.data.ordersToday
            == get(/databases/$(database)/documents/couriers/$(request.auth.uid)).data.ordersToday
              + 1
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'completedAt',
            'updatedAt'
          ]);
      }

      allow create: if signedIn()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == 'waiting'
        && request.resource.data.price is number
        && request.resource.data.price >= 0
        && request.resource.data.currency == 'TJS'
        && request.resource.data.get('courierId', null) == null
        && (authPhone() != null
          || request.resource.data.get('isTestOrder', false) == true)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly([
          'customerId',
          'customerName',
          'status',
          'type',
          'city',
          'fromText',
          'toText',
          'price',
          'currency',
          'confirmationCode',
          'fromLocation',
          'toLocation',
          'distanceKm',
          'etaMinutes',
          'comment',
          'isTestOrder',
          'declinedBy',
          'createdAt',
          'updatedAt'
        ]);

      allow get, list: if signedIn()
        && (isAdmin()
          || resource.data.customerId == request.auth.uid
          || (isCourier() && resource.data.status == 'waiting')
          || resource.data.get('courierId', null) == request.auth.uid);

      allow update: if isAdmin()
        || (signedIn()
          && immutableOrderData()
          && (customerCancels()
            || customerCompletes()
            || customerDisputes()
            || courierDeclines()
            || courierAccepts()
            || courierArrives()
            || courierPicksUp()
            || courierDelivers()
            || courierCompletesWithCode()));

      allow delete: if false;
    }

    match /admin_logs/{logId} {
      allow create, read: if isAdmin();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
